{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/block-dangerous.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "npm run verify:fast 2>&1 | tail -50" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "npm run verify:full 2>&1 | tail -100" }]
      }
    ],
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/session-context.sh" }]
      }
    ]
  }
}
